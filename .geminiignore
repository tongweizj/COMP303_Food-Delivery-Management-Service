# Gemini Ignore File
# Specifies files and directories that Gemini CLI should ignore.

# Node.js related
node_modules/
dist/
build/
.env
.npm/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.yarn/

# Java/Maven related
target/
.gradle/
.idea/
.vscode/
*.iml
*.iws
*.ipr
.project
.classpath
.settings/

# Git related
.git/
.gitignore

# OS specific
.DS_Store
Thumbs.db

# Gemini CLI specific
.gemini/
.geminiignore

# Log files
*.log
*.tmp
temp/

# Compiled files
*.class
*.jar
*.war

# IDE specific files
*.iml
.idea/
.settings/
.project
.classpath
.factorypath